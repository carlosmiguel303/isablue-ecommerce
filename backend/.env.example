# === Perfil / servidor ===
SPRING_PROFILES_ACTIVE=pdn
PORT=8080

# === Base de datos (Railway Postgres) ===
PGHOST=host-interno-postgres
PGPORT=5432
PGDATABASE=railway
PGUSER=postgres
PGPASSWORD=tu_password

# === URLs (sin valores productivos quemados) ===
CORS_ALLOWED_ORIGINS=https://tu-frontend.example.com
FRONTEND_URL=https://tu-frontend.example.com
BACKEND_BASE_URL=https://tu-backend.example.com
UPLOAD_DIR=/app/uploads

# === Seguridad ===
# Obligatorio en producción (>= 64 caracteres). Ya NO existe valor por defecto en el código.
JWT_SECRET=genera_una_clave_aleatoria_de_al_menos_64_caracteres
JWT_EXPIRATION_MS=1500000

# === Datos demo (desactivados en producción) ===
DEMO_DATA_ENABLED=false
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=

# === Identidad de la tienda / pago manual (configurar con datos reales en Railway) ===
STORE_WHATSAPP=51999999999
YAPE_NUMBER=999999999
YAPE_NAME=Nombre Titular Yape

# === Correo (Brevo) — opcional ===
BREVO_API_KEY=
MAIL_FROM_NAME=Mi Tienda
MAIL_ADMIN_TO=

# === Pagos en línea (módulos opcionales, apagados por defecto) ===
PAYMENTS_ONLINE_ENABLED=false
PAYMENTS_SIMULATED_CARD_ENABLED=false
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
CULQI_PUBLIC_KEY=
CULQI_SECRET_KEY=

# === Facturación electrónica (opcional) ===
NUBEFACT_URL=
NUBEFACT_TOKEN=

# === Google Login (opcional) ===
GOOGLE_CLIENT_ID=
